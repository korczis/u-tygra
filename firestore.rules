rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin-only write, public read for events
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin-only write, public read for food menu
    match /food/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin-only for photos metadata
    match /photos/{photoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin-only settings
    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}

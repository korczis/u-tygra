#!/usr/bin/env bash
# Pre-commit hook for Pivnice U Tygra
# Quality gates validation before commit

set -e

echo "=== Pre-commit Quality Gates ==="

# Phase 1: Zola check (broken links, template errors)
echo "[1/3] Zola validation..."
if command -v zola &> /dev/null; then
  zola check 2>&1 | tail -5
  echo "  Zola check: PASS"
else
  echo "  WARNING: zola not found, skipping"
fi

# Phase 2: Content validation (Czech encoding)
echo "[2/3] Content validation..."
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' '*.html' 2>/dev/null || true)
if [ -n "$STAGED_MD" ]; then
  BAD_ENCODING=$(echo "$STAGED_MD" | xargs file 2>/dev/null | grep -v "UTF-8\|ASCII\|empty" || true)
  if [ -n "$BAD_ENCODING" ]; then
    echo "  ERROR: Non-UTF-8 files detected:"
    echo "$BAD_ENCODING"
    exit 1
  fi
  echo "  Content encoding: PASS"
else
  echo "  No content files staged"
fi

# Phase 3: Doctrine enforcement (NMND + FF + CF)
echo "[3/5] Doctrine enforcement..."
STAGED_HTML=$(git diff --cached --name-only --diff-filter=ACM -- '*.html' 2>/dev/null || true)
if [ -n "$STAGED_HTML" ]; then
  # FF doctrine: No Flowbite JS import (CSS only)
  FLOWBITE_JS=$(echo "$STAGED_HTML" | xargs grep -l "flowbite\.min\.js\|flowbite\.js" 2>/dev/null || true)
  if [ -n "$FLOWBITE_JS" ]; then
    echo "  ERROR [FF doctrine]: Flowbite JS import detected (CSS only allowed):"
    echo "$FLOWBITE_JS"
    exit 1
  fi
  echo "  Flowbite First: PASS"
fi

STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM -- 'static/js/*.js' 2>/dev/null || true)
if [ -n "$STAGED_JS" ]; then
  # NMND doctrine: No TODO/FIXME in production JS
  TODOS=$(echo "$STAGED_JS" | xargs grep -l "TODO\|FIXME\|HACK\|XXX" 2>/dev/null || true)
  if [ -n "$TODOS" ]; then
    echo "  WARNING [NMND doctrine]: TODO/FIXME found in:"
    echo "$TODOS"
  fi
  echo "  NMND compliance: PASS"
fi

# Phase 4: No secrets check
echo "[4/5] Security check..."
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -n "$STAGED_ALL" ]; then
  SECRETS=$(echo "$STAGED_ALL" | xargs grep -l -E "(api_key|secret_key|password|token)\s*[:=]\s*['\"][^'\"]+['\"]" 2>/dev/null || true)
  if [ -n "$SECRETS" ]; then
    echo "  ERROR: Potential secrets detected in:"
    echo "$SECRETS"
    exit 1
  fi
  echo "  Security: PASS"
fi

# Phase 5: Diacritics check (CF doctrine)
echo "[5/5] Czech diacritics check..."
if [ -n "$STAGED_HTML" ]; then
  # Check for common Czech words without diacritics in templates
  MISSING_DIACRITICS=$(echo "$STAGED_HTML" | xargs grep -n "Oteviraci\|Flexibilni\|Luzanky\|Pionyrska\|Denne " 2>/dev/null || true)
  if [ -n "$MISSING_DIACRITICS" ]; then
    echo "  WARNING [CF doctrine]: Missing Czech diacritics:"
    echo "$MISSING_DIACRITICS"
  fi
  echo "  Czech First: PASS"
fi

# Phase 6: No Unicode escapes in JS (UTF-8 doctrine)
echo "[6/6] Unicode escape check..."
if [ -n "$STAGED_JS" ]; then
  UNICODE_ESCAPES=$(echo "$STAGED_JS" | xargs grep -n '\\u[0-9a-fA-F]\{4\}' 2>/dev/null || true)
  if [ -n "$UNICODE_ESCAPES" ]; then
    echo "  ERROR [UTF-8 doctrine]: Unicode escapes found (use direct UTF-8 characters):"
    echo "$UNICODE_ESCAPES" | head -5
    echo "  Fix: Replace \\uXXXX with actual Czech characters (ě, š, č, ř, ž, ý, á, í, é, ú, ů, ť, ď, ň)"
    exit 1
  fi
  echo "  UTF-8 doctrine: PASS"
fi

echo "=== All quality gates passed (6/6) ==="

#!/usr/bin/env bash
# AIAD Command: test-links
# Comprehensive link integrity testing for U Tygra project

set -uo pipefail

# AIAD Command Metadata
COMMAND_NAME="test-links"
COMMAND_VERSION="1.0.0"
COMMAND_CATEGORY="quality_maintenance"
COMMAND_DESCRIPTION="Comprehensive link integrity testing for all external URLs, internal paths, and data endpoints"
AIAD_NAMESPACE="u-tygra"

# Configuration
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
REPORTS_DIR="${PROJECT_ROOT}/reports/link-integrity"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
PUBLIC_DIR="${PROJECT_ROOT}/public"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Counters
PASS_COUNT=0
FAIL_COUNT=0
SKIP_COUNT=0

# Temp file for results (atomic writes from parallel jobs)
RESULTS_FILE=$(mktemp)
trap 'rm -f "$RESULTS_FILE" "$LOCK_FILE" 2>/dev/null' EXIT
LOCK_FILE=$(mktemp)

# Logging functions
log() {
    echo -e "${BLUE}[$(date +'%H:%M:%S')]${NC} $1"
}

error() {
    echo -e "${RED}[FAIL]${NC} $1" >&2
}

warning() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

success() {
    echo -e "${GREEN}[PASS]${NC} $1"
}

# Help function
show_help() {
    cat << EOF
AIAD Command: ${COMMAND_NAME} v${COMMAND_VERSION}

DESCRIPTION:
    ${COMMAND_DESCRIPTION}

USAGE:
    ${COMMAND_NAME} [OPTIONS]

OPTIONS:
    -h, --help            Show this help message
    -v, --verbose         Show per-URL status
    --timeout N           Curl timeout in seconds (default: 10)
    --parallel N          Max parallel requests (default: 8)
    --skip-external       Skip external URL checks (offline mode)
    --skip-internal       Skip internal path checks
    --skip-data           Skip Google Sheets data validation
    --external-only       Only run external URL checks
    --internal-only       Only run internal path checks
    --data-only           Only run data endpoint validation
    -f, --format FORMAT   Output format (console, json)
    -o, --output FILE     Output file path

EXAMPLES:
    ${COMMAND_NAME}                      # Full link integrity test
    ${COMMAND_NAME} --verbose            # Full test with per-URL output
    ${COMMAND_NAME} --external-only      # Only external URLs
    ${COMMAND_NAME} --internal-only      # Only internal paths (needs build)
    ${COMMAND_NAME} --data-only          # Only Google Sheets CSV
    ${COMMAND_NAME} --skip-external      # Offline mode

AIAD INTEGRATION:
    Agent: link-integrity-checker
    Quality Gate: link_integrity (blocking)

EOF
}

# Parse arguments
VERBOSE=false
TIMEOUT=10
MAX_PARALLEL=8
SKIP_EXTERNAL=false
SKIP_INTERNAL=false
SKIP_DATA=false
EXTERNAL_ONLY=false
INTERNAL_ONLY=false
DATA_ONLY=false
OUTPUT_FORMAT="console"
OUTPUT_FILE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            show_help
            exit 0
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        --timeout)
            TIMEOUT="$2"
            shift 2
            ;;
        --parallel)
            MAX_PARALLEL="$2"
            shift 2
            ;;
        --skip-external)
            SKIP_EXTERNAL=true
            shift
            ;;
        --skip-internal)
            SKIP_INTERNAL=true
            shift
            ;;
        --skip-data)
            SKIP_DATA=true
            shift
            ;;
        --external-only)
            EXTERNAL_ONLY=true
            SKIP_INTERNAL=true
            SKIP_DATA=true
            shift
            ;;
        --internal-only)
            INTERNAL_ONLY=true
            SKIP_EXTERNAL=true
            SKIP_DATA=true
            shift
            ;;
        --data-only)
            DATA_ONLY=true
            SKIP_EXTERNAL=true
            SKIP_INTERNAL=true
            shift
            ;;
        -f|--format)
            OUTPUT_FORMAT="$2"
            shift 2
            ;;
        -o|--output)
            OUTPUT_FILE="$2"
            shift 2
            ;;
        *)
            error "Unknown option: $1"
            show_help
            exit 1
            ;;
    esac
done

mkdir -p "${REPORTS_DIR}"
cd "${PROJECT_ROOT}"


# ─────────────────────────────────────────────
# URL checking function
# ─────────────────────────────────────────────

check_url() {
    local url="$1"
    local category="$2"

    local result
    result=$(curl -L -s -o /dev/null \
        -w "%{http_code}|%{time_total}" \
        --max-time "${TIMEOUT}" \
        -A "Mozilla/5.0 (compatible; U-Tygra-LinkChecker/1.0)" \
        "$url" 2>/dev/null) || result="000|0"

    local http_code="${result%%|*}"
    local time_total="${result#*|}"

    if [[ "$http_code" =~ ^(200|301|302|303|307|308)$ ]]; then
        if [[ "$VERBOSE" = true ]]; then
            echo -e "  ${GREEN}PASS${NC} [${http_code}] ${time_total}s  ${url}"
        fi
        echo "PASS|${http_code}|${time_total}|${category}|${url}" >> "$RESULTS_FILE"
    else
        echo -e "  ${RED}FAIL${NC} [${http_code}] ${time_total}s  ${url}"
        echo "FAIL|${http_code}|${time_total}|${category}|${url}" >> "$RESULTS_FILE"
    fi
}

# ─────────────────────────────────────────────
# Parallel runner (macOS/Linux compatible)
# ─────────────────────────────────────────────

run_checks() {
    local category="$1"
    shift
    local urls=("$@")
    local running=0

    for url in "${urls[@]}"; do
        check_url "$url" "$category" &
        running=$((running + 1))

        if [[ $running -ge $MAX_PARALLEL ]]; then
            wait -n 2>/dev/null || wait
            running=$((running - 1))
        fi
    done
    wait
}

# ─────────────────────────────────────────────
# Section 1: External URL checks
# ─────────────────────────────────────────────

check_external() {
    echo ""
    echo -e "${BOLD}External URL Checks${NC}"
    echo "────────────────────────────────────────"

    echo -e "\n${CYAN}Brewery websites (${#BREWERY_URLS[@]} URLs)${NC}"
    run_checks "brewery" "${BREWERY_URLS[@]}"

    echo -e "\n${CYAN}CDN resources (${#CDN_URLS[@]} URLs)${NC}"
    run_checks "cdn" "${CDN_URLS[@]}"

    echo -e "\n${CYAN}Service URLs (${#SERVICE_URLS[@]} URLs)${NC}"
    run_checks "service" "${SERVICE_URLS[@]}"
}

# ─────────────────────────────────────────────
# Section 2: Internal path checks
# ─────────────────────────────────────────────

check_internal() {
    echo ""
    echo -e "${BOLD}Internal Path Checks${NC}"
    echo "────────────────────────────────────────"

    if [[ ! -d "$PUBLIC_DIR" ]]; then
        error "public/ not found. Run 'zola build' first."
        echo "FAIL|NOBUILD|0|internal|public_directory" >> "$RESULTS_FILE"
        return 1
    fi

    local section=""
    for path in "${INTERNAL_PATHS[@]}"; do
        # Section headers
        local new_section=""
        case "$path" in
            js/*)  new_section="JavaScript" ;;
            css/*) new_section="CSS" ;;
            img/gallery/*) new_section="Gallery images" ;;
            img/*) new_section="Images" ;;
            *)     new_section="Root files" ;;
        esac
        if [[ "$new_section" != "$section" ]]; then
            section="$new_section"
            echo -e "\n${CYAN}${section}${NC}"
        fi

        local full_path="${PUBLIC_DIR}/${path}"
        if [[ -f "$full_path" ]]; then
            local size
            size=$(wc -c < "$full_path" | tr -d ' ')
            if [[ "$size" -eq 0 ]]; then
                echo -e "  ${RED}FAIL${NC} [EMPTY]    /${path}"
                echo "FAIL|EMPTY|0|internal|/${path}" >> "$RESULTS_FILE"
            else
                if [[ "$VERBOSE" = true ]]; then
                    echo -e "  ${GREEN}PASS${NC} [${size}B]  /${path}"
                fi
                echo "PASS|EXISTS|${size}|internal|/${path}" >> "$RESULTS_FILE"
            fi
        else
            echo -e "  ${RED}FAIL${NC} [MISSING]  /${path}"
            echo "FAIL|MISSING|0|internal|/${path}" >> "$RESULTS_FILE"
        fi
    done
}

# ─────────────────────────────────────────────
# Section 3: Google Sheets CSV data validation
# ─────────────────────────────────────────────

check_data() {
    echo ""
    echo -e "${BOLD}Google Sheets Data Validation${NC}"
    echo "────────────────────────────────────────"

    local tmpfile
    tmpfile=$(mktemp)
    local http_code
    local attempt=1
    local max_attempts=2

    while [[ $attempt -le $max_attempts ]]; do
        http_code=$(curl -L -s -o "$tmpfile" -w "%{http_code}" \
            --max-time 15 \
            -A "Mozilla/5.0 (compatible; U-Tygra-LinkChecker/1.0)" \
            "$GOOGLE_SHEETS_CSV" 2>/dev/null) || http_code="000"

        if [[ "$http_code" == "200" ]]; then
            break
        fi

        if [[ $attempt -lt $max_attempts ]]; then
            warning "Attempt $attempt failed (HTTP $http_code), retrying in 3s..."
            sleep 3
        fi
        attempt=$((attempt + 1))
    done

    # Check 1: HTTP status
    echo -e "\n${CYAN}Endpoint connectivity${NC}"
    if [[ "$http_code" != "200" ]]; then
        echo -e "  ${RED}FAIL${NC} HTTP status: ${http_code}"
        echo "FAIL|${http_code}|0|data|csv_http_status" >> "$RESULTS_FILE"
        rm -f "$tmpfile"
        return
    fi
    echo -e "  ${GREEN}PASS${NC} HTTP status: 200"
    echo "PASS|200|0|data|csv_http_status" >> "$RESULTS_FILE"

    # Check 2: Non-empty response
    echo -e "\n${CYAN}Response content${NC}"
    local byte_count
    byte_count=$(wc -c < "$tmpfile" | tr -d ' ')
    if [[ "$byte_count" -lt 10 ]]; then
        echo -e "  ${RED}FAIL${NC} Response too small: ${byte_count} bytes"
        echo "FAIL|EMPTY|${byte_count}|data|csv_content_size" >> "$RESULTS_FILE"
        rm -f "$tmpfile"
        return
    fi
    echo -e "  ${GREEN}PASS${NC} Response size: ${byte_count} bytes"
    echo "PASS|SIZE|${byte_count}|data|csv_content_size" >> "$RESULTS_FILE"

    # Check 3: Multiple rows (has beer data)
    echo -e "\n${CYAN}Data structure${NC}"
    local line_count
    line_count=$(wc -l < "$tmpfile" | tr -d ' ')
    if [[ "$line_count" -lt 2 ]]; then
        echo -e "  ${RED}FAIL${NC} Too few rows: ${line_count} (need >= 2)"
        echo "FAIL|ROWS|${line_count}|data|csv_row_count" >> "$RESULTS_FILE"
    else
        echo -e "  ${GREEN}PASS${NC} Row count: ${line_count}"
        echo "PASS|ROWS|${line_count}|data|csv_row_count" >> "$RESULTS_FILE"
    fi

    # Check 4: Comma-separated structure
    local comma_count
    comma_count=$(tr -cd ',' < "$tmpfile" | wc -c | tr -d ' ')
    local avg_commas=0
    if [[ "$line_count" -gt 0 ]]; then
        avg_commas=$((comma_count / line_count))
    fi
    if [[ "$avg_commas" -lt 2 ]]; then
        echo -e "  ${RED}FAIL${NC} Not enough columns (avg ${avg_commas} commas/row)"
        echo "FAIL|COLUMNS|${avg_commas}|data|csv_column_count" >> "$RESULTS_FILE"
    else
        echo -e "  ${GREEN}PASS${NC} Column structure: avg ${avg_commas} columns/row"
        echo "PASS|COLUMNS|${avg_commas}|data|csv_column_count" >> "$RESULTS_FILE"
    fi

    # Check 5: Contains beer-like data (non-empty second+ rows with text)
    local data_rows
    data_rows=$(tail -n +2 "$tmpfile" | grep -c '[a-zA-Z]' || true)
    if [[ "$data_rows" -lt 1 ]]; then
        echo -e "  ${RED}FAIL${NC} No beer data rows found"
        echo "FAIL|NODATA|0|data|csv_beer_data" >> "$RESULTS_FILE"
    else
        echo -e "  ${GREEN}PASS${NC} Beer data rows: ${data_rows}"
        echo "PASS|DATA|${data_rows}|data|csv_beer_data" >> "$RESULTS_FILE"
    fi

    rm -f "$tmpfile"
}

# ─────────────────────────────────────────────
# Summary
# ─────────────────────────────────────────────

generate_summary() {
    # Count results
    PASS_COUNT=$(grep -c "^PASS" "$RESULTS_FILE" 2>/dev/null || true)
    FAIL_COUNT=$(grep -c "^FAIL" "$RESULTS_FILE" 2>/dev/null || true)
    PASS_COUNT=${PASS_COUNT:-0}
    FAIL_COUNT=${FAIL_COUNT:-0}
    # Strip whitespace (macOS wc adds leading spaces)
    PASS_COUNT=$(echo "$PASS_COUNT" | tr -d '[:space:]')
    FAIL_COUNT=$(echo "$FAIL_COUNT" | tr -d '[:space:]')
    [[ -z "$PASS_COUNT" ]] && PASS_COUNT=0
    [[ -z "$FAIL_COUNT" ]] && FAIL_COUNT=0
    local total=$((PASS_COUNT + FAIL_COUNT))

    echo ""
    echo -e "${BOLD}════════════════════════════════════════${NC}"
    echo -e "${BOLD}  U Tygra Link Integrity Report${NC}"
    echo -e "${BOLD}════════════════════════════════════════${NC}"
    echo ""
    echo -e "  Total checks:  ${total}"
    echo -e "  ${GREEN}Passed:${NC}        ${PASS_COUNT}"
    echo -e "  ${RED}Failed:${NC}        ${FAIL_COUNT}"
    echo ""

    # Category breakdown
    for cat in brewery cdn service internal data; do
        local cat_total cat_pass cat_fail
        cat_total=$(grep "|${cat}|" "$RESULTS_FILE" 2>/dev/null | wc -l | tr -d '[:space:]')
        cat_pass=$(grep "^PASS" "$RESULTS_FILE" 2>/dev/null | grep "|${cat}|" 2>/dev/null | wc -l | tr -d '[:space:]')
        cat_fail=$(grep "^FAIL" "$RESULTS_FILE" 2>/dev/null | grep "|${cat}|" 2>/dev/null | wc -l | tr -d '[:space:]')
        [[ -z "$cat_total" ]] && cat_total=0
        [[ -z "$cat_pass" ]] && cat_pass=0
        [[ -z "$cat_fail" ]] && cat_fail=0
        if [[ "$cat_total" -gt 0 ]]; then
            if [[ "$cat_fail" -gt 0 ]]; then
                echo -e "  ${RED}FAIL${NC}  ${cat}: ${cat_pass}/${cat_total}"
            else
                echo -e "  ${GREEN}PASS${NC}  ${cat}: ${cat_pass}/${cat_total}"
            fi
        fi
    done

    # Show failures
    if [[ "$FAIL_COUNT" -gt 0 ]]; then
        echo ""
        echo -e "${RED}Failed checks:${NC}"
        while IFS='|' read -r status code detail category url; do
            printf "  ${RED}[%s]${NC} (%s) %s\n" "$code" "$category" "$url"
        done < <(grep "^FAIL" "$RESULTS_FILE" 2>/dev/null || true)
    fi

    echo ""
    echo -e "${BOLD}════════════════════════════════════════${NC}"

    # JSON report
    if [[ "$OUTPUT_FORMAT" == "json" || -n "$OUTPUT_FILE" ]]; then
        local report_path="${OUTPUT_FILE:-${REPORTS_DIR}/link-test-${TIMESTAMP}.json}"
        {
            echo "{"
            echo "  \"metadata\": {"
            echo "    \"command\": \"${COMMAND_NAME}\","
            echo "    \"version\": \"${COMMAND_VERSION}\","
            echo "    \"timestamp\": \"$(date -u +"%Y-%m-%dT%H:%M:%SZ")\","
            echo "    \"timeout\": ${TIMEOUT}"
            echo "  },"
            echo "  \"summary\": {"
            echo "    \"total\": ${total},"
            echo "    \"passed\": ${PASS_COUNT},"
            echo "    \"failed\": ${FAIL_COUNT}"
            echo "  },"
            echo "  \"results\": ["
            local first=true
            while IFS='|' read -r status code detail category url; do
                if [[ "$first" = true ]]; then
                    first=false
                else
                    echo ","
                fi
                printf '    {"status":"%s","code":"%s","detail":"%s","category":"%s","url":"%s"}' \
                    "$status" "$code" "$detail" "$category" "$url"
            done < "$RESULTS_FILE"
            echo ""
            echo "  ]"
            echo "}"
        } > "$report_path"
        log "Report saved: ${report_path}"
    fi

    # Exit code
    if [[ "$FAIL_COUNT" -gt 0 ]]; then
        error "${FAIL_COUNT} check(s) failed."
        return 1
    else
        success "All ${total} checks passed."
        return 0
    fi
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────

echo -e "${BOLD}U Tygra Link Integrity Test${NC}"
echo -e "Version ${COMMAND_VERSION} | Timeout ${TIMEOUT}s | Parallel ${MAX_PARALLEL}"
echo ""

if [[ "$SKIP_EXTERNAL" != true ]]; then
    check_external
fi

if [[ "$SKIP_INTERNAL" != true ]]; then
    check_internal
fi

if [[ "$SKIP_DATA" != true ]]; then
    check_data
fi

generate_summary
exit $?

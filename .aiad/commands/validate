#!/usr/bin/env bash
# AIAD Command: validate
# Quick pre-push validation: build + check + internal links
set -euo pipefail

echo "=== U Tygra Pre-Push Validation ==="
echo ""

# Phase 1: Zola check
echo "[1/3] Zola check..."
zola check 2>&1 | tail -3
echo "  PASS"

# Phase 2: Build
echo "[2/3] Building..."
zola build > /dev/null 2>&1
echo "  PASS ($(find public -type f | wc -l | tr -d ' ') files)"

# Phase 3: Internal links
echo "[3/3] Internal links..."
MISSING=0
for f in js/app.js js/csv-worker.js css/style.css img/logo.svg img/hero-bg.jpg index.html site.webmanifest; do
  if [ ! -f "public/$f" ]; then
    echo "  MISSING: $f"
    MISSING=$((MISSING + 1))
  fi
done

if [ $MISSING -eq 0 ]; then
  echo "  PASS (critical assets verified)"
else
  echo "  FAIL ($MISSING missing)"
  exit 1
fi

echo ""
echo "=== All checks passed ==="
